# Signing keys (NEVER commit private keys)
.tauri/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules
.pnp
.pnp.js
.pnpm-store/

# Build outputs
dist
dist-ssr
*.local
build
out

# Testing
coverage
.nyc_output

# Environment files & Secrets - NEVER commit these
.env
.env.*
!.env.example
!.env.web.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
secrets.json
credentials.json
