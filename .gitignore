# Donkeyfolio changes reference (safe to keep but not needed in prod)
donkeyfolio-changes/

# Personal/project planning content (not for commit)
App/
ideas/

# Auto-generated lefthook config (from rebalancer addon postinstall)
/lefthook.yml

# Generated from tauri.conf.template.json by scripts/gen-tauri-conf.mjs
# (committed value would be hardcoded fork-specific data — we generate
#  from .env.local at build time instead)
/apps/tauri/tauri.conf.json

