# Donkeyfolio - Environment Configuration
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control (it's gitignored).
# Values with DONKEYFOLIO_ prefix are compiled into the binary / bundled
# into the web build; treat them as public.

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=../db/app.db

# ─── Fork identity (change these when forking) ────────────────────────
# Your GitHub username/organization that hosts the Donkeyfolio fork.
DONKEYFOLIO_GITHUB_OWNER=LGNative
# Repository name.
DONKEYFOLIO_GITHUB_REPO=donkeyfolio
# Contact email shown in the About page.
DONKEYFOLIO_SUPPORT_EMAIL=peauntidonky.digital@gmail.com

# ─── App branding ─────────────────────────────────────────────────────
DONKEYFOLIO_APP_NAME=Donkeyfolio
DONKEYFOLIO_BUNDLE_ID=com.luisgoncalves.donkeyfolio
DONKEYFOLIO_DEEP_LINK_SCHEME=donkeyfolio
DONKEYFOLIO_COPYRIGHT=2026 Luis Goncalves
# Apple Developer team ID (only used for iOS builds, empty is OK for macOS)
DONKEYFOLIO_APPLE_TEAM_ID=DYDJ2RNL5H

# ─── Keychain namespace ───────────────────────────────────────────────
# Prefix for all secret identifiers stored in the OS keychain.
# IMPORTANT: changing this AFTER first install means existing entries are
# orphaned — user has to re-enter API keys (they're not migrated).
# Use the default "wealthfolio_" to stay compatible with upstream, or
# change to e.g. "donkeyfolio_" to isolate the fork's keychain namespace.
DONKEYFOLIO_SECRET_PREFIX=donkeyfolio_

# ─── Addon store ──────────────────────────────────────────────────────
# Endpoint returning {"addons": [...]} JSON. Default: jsDelivr CDN of
# docs/addons.json in the fork repo (free, fast, no infra needed).
DONKEYFOLIO_ADDON_STORE_URL=https://cdn.jsdelivr.net/gh/LGNative/donkeyfolio@main/docs/addons.json

# ─── Auto-updater ─────────────────────────────────────────────────────
# URL where the Tauri updater fetches latest.json (published per release).
DONKEYFOLIO_UPDATER_ENDPOINT=https://github.com/LGNative/donkeyfolio/releases/latest/download/latest.json
# Public signing key (base64 minisign format). Generate with:
#   npx @tauri-apps/cli signer generate --ci -w ~/.tauri/donkeyfolio.key
# Then paste the contents of ~/.tauri/donkeyfolio.key.pub below.
DONKEYFOLIO_UPDATER_PUBKEY=dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NjRGMzJEODY3MDMxQTcKUldTbk1YQ0dMZk5rNkt0Smx1MktPazdQZ3FIQW50K2dIZXNTbFpSb3JEaHlJZjZIVFNQSS9UbTEK

# ─── Tauri build-time secrets (NEVER commit values) ───────────────────
# Path to the private signing key (used by CI to sign updater artifacts).
# Locally this is typically ~/.tauri/donkeyfolio.key.
# TAURI_SIGNING_PRIVATE_KEY_PATH=

# ─── Web mode (optional, only if using Axum server) ───────────────────
# See .env.web.example for the full web/server configuration.
