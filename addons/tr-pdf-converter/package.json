{
  "name": "tr-pdf-converter",
  "version": "2.7.6",
  "description": "Native React TR PDF parser (ported from jcmpagel's open-source converter)",
  "type": "module",
  "main": "dist/addon.js",
  "author": "Donkeyfolio",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist",
    "package": "mkdir -p dist && zip -r dist/$npm_package_name-$npm_package_version.zip manifest.json dist/addon.js",
    "bundle": "pnpm clean && pnpm build && pnpm package",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wealthfolio/addon-sdk": "*",
    "@wealthfolio/ui": "*",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
